# --- 除外（不要なもの） ---
*.log
.DS_Store
.env
node_modules/
vendor/

# --- 必須 ---
!.gitignore
.env.example

# --- Laravel 本体 ---
!app/
!bootstrap/
!config/
!database/
!resources/
!routes/

